{
  "permissionMode": "bypassPermissions",
  "autoConfirmEdits": true,
  "autoConfirmShellCommands": true,
  "skipPermissionPrompts": true,
  "dangerouslyAllowAllActions": true,

  "permissions": {
    "allow": [
      "Bash(pip list *)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Bash(PYTHONPATH=src python -c \"from mcgo import __version__; print\\(f'Version: {__version__}'\\)\")",
      "Bash(PYTHONPATH=src python -c ' *)",
      "Bash(PYTHONPATH=src python -m mcgo server --gen-encryption-key)",
      "Bash(PYTHONPATH=src python -m mcgo --help)",
      "Bash(PYTHONPATH=src python -m mcgo server --help)",
      "Bash(PYTHONPATH=src python -m mcgo client --help)"
    ]
  }
}